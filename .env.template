# JWT Secret - Used to sign authentication tokens
# Generate: openssl rand -base64 32
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Supabase Keys (Must be JWTs signed with your JWT_SECRET)
# See README.md for instructions on how to generate these for your secret.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PostgreSQL Database Password
POSTGRES_PASSWORD=

# ==============================================
# 🌐 Service URLs & Ports
# ==============================================
# Docker Compose exposes the following ports:
#   3000  - Frontend (Next.js)
#   54321 - Supabase API (Kong Gateway)
#   54322 - PostgreSQL (Direct Access)
#   54323 - Supabase Studio (Dashboard)
#   54324 - Inbucket (Email Testing UI)
#   54325 - Inbucket (SMTP)

# Supabase API URL (accessible from browser)
# Development: Use 127.0.0.1 instead of localhost to avoid IPv4/IPv6 issues
# Production: https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Frontend site URL (used for OAuth redirect callbacks)
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Internal Supabase API URL (used by backend services)
# This should point to Kong gateway within Docker network
SUPABASE_PUBLIC_URL=http://localhost:54321

# GoTrue (Auth) External URL
# This is how external clients reach the auth service
API_EXTERNAL_URL=http://localhost:54321

# GoTrue Site URL (where users are redirected after auth)
GOTRUE_SITE_URL=http://localhost:3000

# ==============================================
# 🗺️ Google Maps API Key
# ==============================================
# Get your key from: https://console.cloud.google.com/apis/credentials
# Required APIs: Maps JavaScript API, Places API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
